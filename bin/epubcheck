#!/usr/bin/env bash
set -euo pipefail
EPUB_FILE="${1:?Usage: epubcheck <file.epub>}"
LOG_DIR="${ARTIFACTS_DIR:-test-results/epubcheck}"
mkdir -p "$LOG_DIR"
TS=$(date +%Y%m%d-%H%M%S)
LOG="$LOG_DIR/epubcheck-${TS}.log.txt"
echo "=== EPUBCheck ===" | tee "$LOG"
if command -v epubcheck >/dev/null 2>&1; then
  epubcheck --locale en --profile default "$EPUB_FILE" 2>&1 | tee -a "$LOG"
else
  echo "[FAIL] epubcheck not found" | tee -a "$LOG"
  exit 1
fi
echo "Log: $LOG"
